# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/notes_app_db

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Application Configuration
APP_NAME=Notes App
DEBUG=true
ENVIRONMENT=development

# Enhanced Logging Configuration
# Set to DEBUG, INFO, WARNING, ERROR, or CRITICAL (respects .env setting)
LOG_LEVEL=INFO
LOG_FORMAT=text
# Per-module log level overrides (JSON format)
# MODULE_LOG_LEVELS={"src.api": "DEBUG", "src.core": "INFO", "src.services": "WARNING", "sqlalchemy.engine": "WARNING"}
# Enable colored logs in development
ENABLE_COLORED_LOGS=true
# Enable file and line number in logs
ENABLE_FILE_LINE_INFO=true
# Enable user context in logs
ENABLE_USER_CONTEXT=true
# Enable request context in logs
ENABLE_REQUEST_CONTEXT=true
# User information to display in logs
SHOW_USER_EMAIL=true
SHOW_USER_USERNAME=true
SHOW_USER_FULL_NAME=true
SHOW_USER_DISPLAY_NAME=true
# Enable AWS X-Ray tracing
ENABLE_XRAY_TRACING=false

# Performance and Security Logging
ENABLE_PERFORMANCE_LOGGING=true
ENABLE_SECURITY_LOGGING=true
ENABLE_DATABASE_LOGGING=true
LOG_SLOW_QUERIES=true
SLOW_QUERY_THRESHOLD_MS=1000

# Log rotation and retention
LOG_ROTATION_SIZE_MB=100
LOG_RETENTION_DAYS=30

# Log sampling for high-volume operations
ENABLE_LOG_SAMPLING=false
LOG_SAMPLING_RATE=0.1

# Testing Configuration
# Enable authentication bypass for testing
AUTH_BYPASS=false
# Test user credentials for bypass
TEST_USER_ID=test-user-123
TEST_USER_EMAIL=test@example.com
TEST_USER_USERNAME=testuser

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# Security
BCRYPT_ROUNDS=12
