# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/notes_app_db

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Application Configuration
APP_NAME=Notes App
DEBUG=true
ENVIRONMENT=development

# Logging Configuration
# Leave empty for environment-based default (DEBUG for development, INFO for testing, WARNING for staging, ERROR for production)
LOG_LEVEL=
LOG_FORMAT=json
# Per-module log level overrides (optional)
# MODULE_LOG_LEVELS={"src.api": "DEBUG", "src.core": "INFO", "src.services": "WARNING"}

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# Security
BCRYPT_ROUNDS=12
